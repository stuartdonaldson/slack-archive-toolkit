#!/usr/bin/env python3
"""Repo-root convenience entry point - equivalent to `python -m slackbackup.cli`.
Runs under whatever `python3` is on PATH (activate the project venv first); it
inserts ./src itself, so no install is strictly required.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent / "src"))

from slackbackup.cli import main

if __name__ == "__main__":
    sys.exit(main())
