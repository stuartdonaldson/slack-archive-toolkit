
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Python
.venv/
__pycache__/
*.egg-info/
.pytest_cache/

# Node (scripts/auth-refresh helper)
node_modules/
package-lock.json

# Secrets - slackdump tokens/cookies belong in $HOME (~/.slackdump-tokens.json),
# never in this repo, but ignore defensively in case one ever lands here.
.env
.env.*
*.slackdump-tokens.json
*token*.json
*cookie*

# Generated outputs (real Slack content) - belong in ~/slack-backups /
# ~/slack-exports, never in this repo.
search-results.html

# Operator's real tracked-channel list - grows via `channel register`/
# `channel register-matching`, reveals which real workspaces/channels are
# being backed up. Not source; never committed.
channels.json
